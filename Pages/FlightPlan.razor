@page "/flight-plan"

<PageTitle>飛行計畫</PageTitle>

<section class="flight-hero">
    <div>
        <p class="eyebrow">飛行計畫</p>
        <h1>台灣出發亞洲直航航線</h1>
        <p class="hero-summary">
            整理松山、桃園、台中與小港機場出發的亞洲直航航線，並標記航空公司與所屬航空聯盟。
        </p>
    </div>
    <div class="flight-summary-card">
        <span class="metric-label">目前收錄</span>
        <strong>@FilteredRoutes.Count</strong>
        <p>篩選後航線 / 共 @Routes.Count 筆資料</p>
    </div>
</section>

<section class="panel flight-filter-panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">線上篩選</p>
            <h2>依機場、地區、聯盟與航空公司查詢</h2>
        </div>
        <button class="filter-reset" type="button" @onclick="ResetFilters">清除篩選</button>
    </div>

    <div class="flight-filters">
        <label>
            <span>關鍵字</span>
            <input @bind="SearchText" @bind:event="oninput" placeholder="輸入城市、國家、航司或航點" />
        </label>
        <label>
            <span>出發機場</span>
            <select @bind="SelectedAirport">
                <option value="">全部機場</option>
                @foreach (var airport in Airports)
                {
                    <option value="@airport">@airport</option>
                }
            </select>
        </label>
        <label>
            <span>亞洲區域</span>
            <select @bind="SelectedRegion">
                <option value="">全部區域</option>
                @foreach (var region in Regions)
                {
                    <option value="@region">@region</option>
                }
            </select>
        </label>
        <label>
            <span>航空聯盟</span>
            <select @bind="SelectedAlliance">
                <option value="">全部聯盟</option>
                @foreach (var alliance in Alliances)
                {
                    <option value="@alliance">@alliance</option>
                }
            </select>
        </label>
        <label>
            <span>航空公司</span>
            <select @bind="SelectedAirline">
                <option value="">全部航空公司</option>
                @foreach (var airline in Airlines)
                {
                    <option value="@airline">@airline</option>
                }
            </select>
        </label>
    </div>
</section>

<section class="metrics-grid flight-stat-grid">
    @foreach (var stat in AirportStats)
    {
        <article class="metric-card">
            <span class="metric-label">@stat.Airport</span>
            <strong>@stat.Count</strong>
            <p>@stat.Destinations 個目的地、@stat.Airlines 家航空公司</p>
        </article>
    }
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">航線清單</p>
            <h2>亞洲直航資料</h2>
        </div>
        <span class="muted">小港依高雄官方定期班表補齊，台中依官方國際/兩岸航點補齊</span>
    </div>

    <div class="table-shell">
        <table class="flight-table">
            <thead>
                <tr>
                    <th>出發機場</th>
                    <th>目的地</th>
                    <th>地區</th>
                    <th>航空公司</th>
                    <th>航空聯盟</th>
                    <th>備註</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var route in FilteredRoutes)
                {
                    <tr>
                        <td>
                            <strong>@route.DepartureAirport</strong>
                            <div class="cell-note">@route.DepartureCode</div>
                        </td>
                        <td>
                            <strong>@route.Destination</strong>
                            <div class="cell-note">@route.DestinationAirport</div>
                        </td>
                        <td>@route.Region</td>
                        <td>@route.Airline</td>
                        <td>
                            <span class="alliance-pill @GetAllianceClass(route.Alliance)">@route.Alliance</span>
                        </td>
                        <td>@route.Note</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">資料口徑</p>
            <h2>目前整理方式</h2>
        </div>
    </div>
    <ul class="signal-list">
        <li>只收錄亞洲段直航，不含國內線、北美、歐洲與大洋洲。</li>
        <li>「台北機場」在本頁指台北松山機場；「小港機場」指高雄國際機場。</li>
        <li>小港機場依高雄國際航空站定期班表 JSON 彙整國際及兩岸出境目的地與航空公司。</li>
        <li>台中機場依臺中國際機場今明日航班查詢的國際及兩岸航線目的地與航空公司補齊。</li>
        <li>航空聯盟以航空公司正式會員為主；廉航或未入盟航空公司標示為「無」。</li>
        <li>實際班表、季節停飛、包機或共享航班仍以機場與航空公司公告為準。</li>
    </ul>
</section>

@code {
    private string SearchText { get; set; } = "";
    private string SelectedAirport { get; set; } = "";
    private string SelectedRegion { get; set; } = "";
    private string SelectedAlliance { get; set; } = "";
    private string SelectedAirline { get; set; } = "";

    private IReadOnlyList<string> Airports => Routes.Select(route => route.DepartureAirport).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> Regions => Routes.Select(route => route.Region).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> Alliances => Routes.Select(route => route.Alliance).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> Airlines => Routes.Select(route => route.Airline).Distinct().OrderBy(item => item).ToList();

    private IReadOnlyList<FlightRoute> FilteredRoutes => Routes
        .Where(route => string.IsNullOrWhiteSpace(SelectedAirport) || route.DepartureAirport == SelectedAirport)
        .Where(route => string.IsNullOrWhiteSpace(SelectedRegion) || route.Region == SelectedRegion)
        .Where(route => string.IsNullOrWhiteSpace(SelectedAlliance) || route.Alliance == SelectedAlliance)
        .Where(route => string.IsNullOrWhiteSpace(SelectedAirline) || route.Airline == SelectedAirline)
        .Where(MatchesSearch)
        .OrderBy(route => route.DepartureAirport)
        .ThenBy(route => route.Region)
        .ThenBy(route => route.Destination)
        .ThenBy(route => route.Airline)
        .ToList();

    private IReadOnlyList<AirportStat> AirportStats => FilteredRoutes
        .GroupBy(route => route.DepartureAirport)
        .Select(group => new AirportStat(
            group.Key,
            group.Count(),
            group.Select(route => route.Destination).Distinct().Count(),
            group.Select(route => route.Airline).Distinct().Count()))
        .OrderBy(stat => stat.Airport)
        .ToList();

    private bool MatchesSearch(FlightRoute route)
    {
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            return true;
        }

        var keyword = SearchText.Trim();
        return route.DepartureAirport.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || route.DepartureCode.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || route.Destination.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || route.DestinationAirport.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || route.Region.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || route.Airline.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || route.Alliance.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || route.Note.Contains(keyword, StringComparison.OrdinalIgnoreCase);
    }

    private void ResetFilters()
    {
        SearchText = "";
        SelectedAirport = "";
        SelectedRegion = "";
        SelectedAlliance = "";
        SelectedAirline = "";
    }

    private static string GetAllianceClass(string alliance)
    {
        return alliance switch
        {
            "星空聯盟" => "star",
            "天合聯盟" => "skyteam",
            "寰宇一家" => "oneworld",
            "星空聯盟 Connecting Partner" => "star",
            _ => "none"
        };
    }


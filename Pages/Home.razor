@page "/"
@implements IAsyncDisposable
@inject retirement_dashboard.Services.PlanDataService PlanDataService

<PageTitle>2030 退休戰情看板</PageTitle>

@if (_isLoading)
{
    <section class="loading-state">
        <p>正在載入退休規劃資料...</p>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="error-state">
        <h1>讀取資料失敗</h1>
        <p>@_errorMessage</p>
    </section>
}
else if (_dashboard is not null)
{
    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">IB 真實持股</p>
                <h2>目前實際持倉</h2>
            </div>
            <span class="muted">@_dashboard.ActualHoldingsSourceText</span>
        </div>
        <div class="metrics-grid">
            <article class="metric-card accent">
                <span class="metric-label">真實持股市值</span>
                <strong>@_dashboard.ActualHoldingsValueText</strong>
                <p>@_dashboard.ActualHoldingsCount 檔持股，與退休情境分開顯示</p>
            </article>
            @foreach (var holding in _dashboard.ActualHoldings)
            {
                <article class="metric-card">
                    <span class="metric-label">@holding.Ticker</span>
                    <strong>@holding.MarketValueText</strong>
                    <p>@holding.Name</p>
                    @if (!string.IsNullOrWhiteSpace(holding.DetailText))
                    {
                        <p class="panel-note">@holding.DetailText</p>
                    }
                </article>
            }
        </div>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">每週二買入計畫</p>
                <h2>年底前追上目標配置</h2>
            </div>
            <span class="muted">@_dashboard.WeeklyBuyPlanWindowText</span>
        </div>
        <div class="metrics-grid">
            <article class="metric-card accent">
                <span class="metric-label">每週二合計買入</span>
                <strong>@_dashboard.WeeklyBuyTotalText</strong>
                <p>依剩餘 @_dashboard.WeeklyBuyTuesdayCount 個星期二平均分攤</p>
            </article>
            @foreach (var plan in _dashboard.WeeklyBuyPlans)
            {
                <article class="metric-card">
                    <span class="metric-label">@plan.Ticker</span>
                    <strong>@plan.WeeklyBuyText</strong>
                    <p>目標 @plan.TargetValueText</p>
                    <p>現有 @plan.CurrentValueText，尚差 @plan.GapValueText</p>
                    <p class="panel-note">@plan.NoteText</p>
                </article>
            }
        </div>
    </section>

    <section class="hero-panel">
        <div class="hero-copy">
            <div class="live-meta">
                <span class="status-pill @(_dashboard.IsLiveData ? "live" : "static")">@(_dashboard.IsLiveData ? "即時資料" : "靜態配置")</span>
                <span>@_dashboard.DataSourceText</span>
                <span>更新時間：@_dashboard.LastUpdatedText</span>
                <span>@_dashboard.RefreshIntervalText</span>
            </div>
            <p class="eyebrow">2030 退休戰情看板</p>
            <h1>先把資產做大，再在退休前兩年逐步轉成現金流。</h1>
            <p class="hero-summary">
                截至 @_dashboard.AsOfDateText，目前退休情境總資產約為 <strong>@FormatCurrency(_dashboard.CurrentAssetTwd, "TWD")</strong>，
                其中股票部位 <strong>@FormatCurrency(_dashboard.CurrentInvestedTwd, "TWD")</strong>，
                定存本金 <strong>@FormatCurrency(_dashboard.FixedDepositPrincipalTwd, "TWD")</strong>。
                依模擬年現金股利推估，現階段每月被動收入約為 <strong>@FormatCurrency(_dashboard.CurrentMonthlyPassiveIncomeTwd, "TWD")</strong>。
            </p>
            @if (!string.IsNullOrWhiteSpace(_dashboard.LiveNotes))
            {
                <p class="panel-note">@_dashboard.LiveNotes</p>
            }
        </div>
        <div class="hero-focus">
            <div class="focus-card">
                <span class="label">目標月退休金</span>
                <strong>@FormatCurrency(_dashboard.TargetMonthlyIncomeTwd, "TWD")</strong>
                <span class="muted">年目標 @FormatCurrency(_dashboard.TargetAnnualIncomeTwd, "TWD")</span>
            </div>
            <div class="focus-card accent">
                <span class="label">4% 法則所需資產</span>
                <strong>@FormatCurrency(_dashboard.TargetCapitalTwd, "TWD")</strong>
                <span class="muted">目前進度 @_dashboard.ProgressPercentText</span>
            </div>
        </div>
    </section>

    <section class="metrics-grid">
        <article class="metric-card">
            <span class="metric-label">目前總進度</span>
            <strong>@_dashboard.ProgressPercentText</strong>
            <p>@FormatCurrency(_dashboard.CurrentAssetTwd, "TWD") / @FormatCurrency(_dashboard.TargetCapitalTwd, "TWD")</p>
            <div class="progress-track">
                <div class="progress-value" style="width:@_dashboard.ProgressPercentCss"></div>
            </div>
        </article>
        <article class="metric-card">
            <span class="metric-label">距離目標時間</span>
            <strong>@_dashboard.MonthsRemaining 個月</strong>
            <p>目標日期：@_dashboard.TargetDateText</p>
        </article>
        <article class="metric-card">
            <span class="metric-label">今年仍需投入</span>
            <strong>@FormatCurrency(_dashboard.AnnualInvestmentGapTwd, "TWD")</strong>
            <p>年度投資目標 @FormatCurrency(_dashboard.AnnualInvestmentTargetTwd, "TWD")</p>
        </article>
        <article class="metric-card">
            <span class="metric-label">定存年利息</span>
            <strong>@FormatCurrency(_dashboard.FixedDepositAnnualInterestTwd, "TWD")</strong>
            <p>定存利率 @_dashboard.FixedDepositRateText</p>
        </article>
        <article class="metric-card">
            <span class="metric-label">目前模擬現金殖利率</span>
            <strong>@_dashboard.LiveIncomeYieldRateText</strong>
            <p>含定存利息與模擬配息版 ETF 的年現金股利</p>
        </article>
        <article class="metric-card accent">
            <span class="metric-label">2030 模擬月退休金</span>
            <strong>@FormatCurrency(_dashboard.LiveProjectedMonthlyIncomeAtTargetTwd, "TWD")</strong>
            <p>依模擬年現金股利推估</p>
        </article>
        <article class="metric-card">
            <span class="metric-label">2030 預估總資產</span>
            <strong>@FormatCurrency(_dashboard.ProjectedPortfolioAtTargetTwd, "TWD")</strong>
            <p>年化報酬假設 @_dashboard.ExpectedAnnualReturnText</p>
        </article>
        <article class="metric-card alert">
            <span class="metric-label">4% 法則月退休金</span>
            <strong>@FormatCurrency(_dashboard.ProjectedMonthlyIncomeAtTargetTwd, "TWD")</strong>
            <p>若 2030 轉成 4% 現金流配置，距目標差額 @FormatCurrency(_dashboard.MonthlyIncomeGapTwd, "TWD")</p>
        </article>
    </section>

    <section class="analysis-grid">
        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">積極版配置</p>
                    <h2>4,500 萬資產拆分</h2>
                </div>
            </div>
            <ul class="signal-list">
                <li>定存固定保留 <strong>@FormatCurrency(_dashboard.FixedDepositPrincipalTwd, "TWD")</strong>，作為安全墊與未來轉倉緩衝。</li>
                <li>股票部位以成長為核心，TSM 與 CSNDX 各自佔整體資產約兩成，波動會比平衡版明顯。</li>
                <li>目前依照配置，年度投資計畫完成度為 <strong>@_dashboard.AnnualPlanProgressText</strong>。</li>
                <li>@(_dashboard.AnnualPlanIsOnTrack ? "今年 3,000 萬股票配置已到位，可以把重點放在再平衡與股價更新。" : $"若要在 {_dashboard.AnnualPlanDeadlineText} 前完成今年配置，平均每月還要投入 {FormatCurrency(_dashboard.RequiredMonthlyInvestmentTwd, "TWD")}。")</li>
            </ul>
            <div class="progress-track">
                <div class="progress-value" style="width:@_dashboard.AnnualPlanProgressCss"></div>
            </div>
        </article>

        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">2030 情境</p>
                    <h2>兩種退休金看法</h2>
                </div>
            </div>
            <ul class="signal-list">
                <li>若沿用 4% 現金流法則，2030 每月約可領 <strong>@FormatCurrency(_dashboard.ProjectedMonthlyIncomeAtTargetTwd, "TWD")</strong>。</li>
                <li>若按目前模擬年現金股利換算，2030 每月約為 <strong>@FormatCurrency(_dashboard.LiveProjectedMonthlyIncomeAtTargetTwd, "TWD")</strong>。</li>
                <li>兩者差距代表你在 2028 到 2030 之間，仍要安排一段把成長資產換成現金流的過程。</li>
                <li>目前投組模擬現金殖利率約 <strong>@_dashboard.CurrentYieldOnCostText</strong>，仍低於 4% 退休提領假設。</li>
            </ul>
        </article>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">退休情境</p>
                <h2>積極版持倉快照</h2>
            </div>
        </div>
        <div class="allocation-list">
            @foreach (var position in _dashboard.Positions)
            {
                <div class="allocation-row">
                    <div>
                        <strong>@position.Ticker</strong>
                        <span>@position.MarketValueText</span>
                    </div>
                    <div class="allocation-bar">
                        <div style="width:@position.AllocationShareCss"></div>
                    </div>
                    <span class="allocation-weight">@position.AllocationShareText</span>
                </div>
            }
        </div>
        <p class="panel-note">
            這裡顯示的是退休情境配置，不是你目前真實持股。真實持倉已另外整理在最上方。
        </p>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">退休情境明細</p>
                <h2>最新價格與模擬現金股利</h2>
            </div>
            <span class="muted">資料日期 @_dashboard.AsOfDateText</span>
        </div>
        <div class="table-shell">
            <table>
                <thead>
                    <tr>
                        <th>代號</th>
                        <th>股數</th>
                        <th>價格</th>
                        <th>市值</th>
                        <th>年現金股利</th>
                        <th>比重</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var position in _dashboard.Positions)
                    {
                        <tr>
                            <td>
                                <strong>@position.Ticker</strong>
                                <div class="cell-note">@position.Name</div>
                            </td>
                            <td>@position.QuantityText</td>
                            <td>@position.PriceText</td>
                            <td>@position.MarketValueText</td>
                            <td>@position.AnnualDividendText</td>
                            <td>@position.AllocationShareText</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="analysis-grid">
        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">歷程紀錄</p>
                    <h2>配置時間軸</h2>
                </div>
            </div>
            <div class="timeline">
                @foreach (var point in _dashboard.History)
                {
                    <div class="timeline-row">
                        <div>
                            <strong>@point.DateText</strong>
                            <span>@point.Note</span>
                        </div>
                        <div>
                            <strong>@point.AssetValueText</strong>
                            <span>@point.ProgressText</span>
                        </div>
                    </div>
                }
            </div>
        </article>

        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">更新流程</p>
                    <h2>Cloudflare 每 2 小時同步</h2>
                </div>
            </div>
            <ol class="step-list">
                <li>最上方區塊顯示依 IB 報告整理的真實持股，其中 2330 先採你提供的約值。</li>
                <li>第二個區塊會把追上退休情境目標市值所需的金額，平均拆到年底前每個星期二。</li>
                <li>下方卡片與表格維持退休情境配置，並改用模擬年現金股利來推估現金流。</li>
            </ol>
            <p class="panel-note">@_dashboard.Notes</p>
        </article>
    </section>
}

@code {
    private retirement_dashboard.Models.RetirementDashboardViewModel? _dashboard;
    private bool _isLoading = true;
    private string? _errorMessage;
    private PeriodicTimer? _refreshTimer;
    private CancellationTokenSource? _refreshCancellation;
    private Task? _refreshLoopTask;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
        StartRefreshLoop();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            _dashboard = await PlanDataService.LoadAsync();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartRefreshLoop()
    {
        _refreshCancellation = new CancellationTokenSource();
        _refreshTimer = new PeriodicTimer(TimeSpan.FromMinutes(_dashboard?.RefreshIntervalMinutes ?? 120));
        _refreshLoopTask = RunRefreshLoopAsync(_refreshCancellation.Token);
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (_refreshTimer is not null && await _refreshTimer.WaitForNextTickAsync(cancellationToken))
            {
                await LoadDashboardAsync();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCancellation is not null)
        {
            _refreshCancellation.Cancel();
            _refreshCancellation.Dispose();
        }

        _refreshTimer?.Dispose();

        if (_refreshLoopTask is not null)
        {
            await _refreshLoopTask;
        }
    }

    private static string FormatCurrency(decimal amount, string currencyCode)
    {
        var symbol = currencyCode == "USD" ? "US$" : "NT$";
        return $"{symbol}{amount:N0}";
    }
}

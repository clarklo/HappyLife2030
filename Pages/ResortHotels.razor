@page "/resort-hotels"

<PageTitle>渡假飯店</PageTitle>

<section class="flight-hero resort-hero">
    <div>
        <p class="eyebrow">渡假飯店</p>
        <h1>親子泳池與溫泉飯店清單</h1>
        <p class="hero-summary">
            先把「小孩玩水爽度」排在飯店豪華度前面，再用高卡待遇、航程與度假完整度做排序。
        </p>
    </div>
    <div class="flight-summary-card">
        <span class="metric-label">目前收錄</span>
        <strong>@FilteredHotels.Count</strong>
        <p>篩選後飯店 / 共 @Hotels.Count 筆資料</p>
    </div>
</section>

<section class="panel flight-filter-panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">線上篩選</p>
            <h2>依大類、集團、地區與高卡價值查詢</h2>
        </div>
        <button class="filter-reset" type="button" @onclick="ResetFilters">清除篩選</button>
    </div>

    <div class="flight-filters resort-filters">
        <label>
            <span>關鍵字</span>
            <input @bind="SearchText" @bind:event="oninput" placeholder="輸入飯店、城市、設施或備註" />
        </label>
        <label>
            <span>大類</span>
            <select @bind="SelectedCategory">
                <option value="">全部大類</option>
                @foreach (var category in Categories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </label>
        <label>
            <span>集團</span>
            <select @bind="SelectedGroup">
                <option value="">全部集團</option>
                @foreach (var group in Groups)
                {
                    <option value="@group">@group</option>
                }
            </select>
        </label>
        <label>
            <span>國家地區</span>
            <select @bind="SelectedCountry">
                <option value="">全部地區</option>
                @foreach (var country in Countries)
                {
                    <option value="@country">@country</option>
                }
            </select>
        </label>
        <label>
            <span>高卡價值</span>
            <select @bind="SelectedEliteValue">
                <option value="">全部</option>
                @foreach (var value in EliteValues)
                {
                    <option value="@value">@value</option>
                }
            </select>
        </label>
    </div>
</section>

<section class="metrics-grid flight-stat-grid">
    @foreach (var stat in CategoryStats)
    {
        <article class="metric-card">
            <span class="metric-label">@stat.Name</span>
            <strong>@stat.Count</strong>
            <p>@stat.Groups 個集團、@stat.Countries 個國家地區</p>
        </article>
    }
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">推薦清單</p>
            <h2>親子渡假飯店排序</h2>
        </div>
        <span class="muted">排序先看親子玩水/泡湯強度，再看高卡與航程</span>
    </div>

    <div class="resort-card-grid">
        @foreach (var hotel in FilteredHotels)
        {
            <article class="resort-card">
                <div class="resort-card-top">
                    <span class="category-pill @GetCategoryClass(hotel.Category)">@hotel.Category</span>
                    <span class="score-pill">@hotel.PriorityText</span>
                </div>
                <h3>@hotel.Name</h3>
                <p class="panel-note">@hotel.Location · @hotel.Group</p>
                <div class="resort-facts">
                    <span>@hotel.EliteValue</span>
                    <span>@hotel.TripStyle</span>
                    <span>@hotel.BestFor</span>
                </div>
                <p>@hotel.Why</p>
                <p class="panel-note">@hotel.Positioning</p>
                <p class="panel-note">訂房前確認：@hotel.CheckBeforeBooking</p>
            </article>
        }
    </div>
</section>

<section class="analysis-grid">
    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">我的排序</p>
                <h2>先看小孩玩水爽度</h2>
            </div>
        </div>
        <ul class="signal-list">
            <li>只看小孩玩水爽度：Holiday Inn Vana Nava Hua Hin、ANA InterContinental Manza、Hilton Bali、Sheraton Grand Danang。</li>
            <li>兼顧高卡待遇與飯店質感：Sheraton Grand Danang、Sofitel Krabi、Sheraton Okinawa Sunmarina、Pullman Phu Quoc。</li>
            <li>短程三天兩夜：沖繩兩間、Hong Kong Ocean Park Marriott；香港可以搭配 Ocean Park 與 Water World。</li>
            <li>溫泉飯店則偏大人放鬆、小孩輕度玩水；若主要目標是滑水道，優先選泳池飯店。</li>
        </ul>
    </article>

    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">訂房提醒</p>
                <h2>三件事要先確認</h2>
            </div>
        </div>
        <ol class="step-list">
            <li>滑水道、水上樂園、海上充氣樂園是否季節開放，颱風季或冬季尤其要確認。</li>
            <li>兒童年齡、身高、救生衣與家長陪同限制；有些滑水道會限制 120cm 以上。</li>
            <li>高卡早餐、酒廊、升等與 resort fee 是否適用該房價，度假村常有例外。</li>
        </ol>
    </article>
</section>

@code {
    private string SearchText { get; set; } = "";
    private string SelectedCategory { get; set; } = "";
    private string SelectedGroup { get; set; } = "";
    private string SelectedCountry { get; set; } = "";
    private string SelectedEliteValue { get; set; } = "";

    private IReadOnlyList<string> Categories => Hotels.Select(hotel => hotel.Category).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> Groups => Hotels.Select(hotel => hotel.Group).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> Countries => Hotels.Select(hotel => hotel.Country).Distinct().OrderBy(item => item).ToList();
    private IReadOnlyList<string> EliteValues => Hotels.Select(hotel => hotel.EliteValue).Distinct().OrderBy(item => item).ToList();

    private IReadOnlyList<ResortHotel> FilteredHotels => Hotels
        .Where(hotel => string.IsNullOrWhiteSpace(SelectedCategory) || hotel.Category == SelectedCategory)
        .Where(hotel => string.IsNullOrWhiteSpace(SelectedGroup) || hotel.Group == SelectedGroup)
        .Where(hotel => string.IsNullOrWhiteSpace(SelectedCountry) || hotel.Country == SelectedCountry)
        .Where(hotel => string.IsNullOrWhiteSpace(SelectedEliteValue) || hotel.EliteValue == SelectedEliteValue)
        .Where(MatchesSearch)
        .OrderBy(hotel => hotel.Priority)
        .ThenBy(hotel => hotel.Country)
        .ThenBy(hotel => hotel.Name)
        .ToList();

    private IReadOnlyList<CategoryStat> CategoryStats => FilteredHotels
        .GroupBy(hotel => hotel.Category)
        .Select(group => new CategoryStat(
            group.Key,
            group.Count(),
            group.Select(hotel => hotel.Group).Distinct().Count(),
            group.Select(hotel => hotel.Country).Distinct().Count()))
        .OrderBy(stat => stat.Name)
        .ToList();

    private bool MatchesSearch(ResortHotel hotel)
    {
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            return true;
        }

        var keyword = SearchText.Trim();
        return hotel.Name.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.Location.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.Country.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.Group.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.Category.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.TripStyle.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.BestFor.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.Why.Contains(keyword, StringComparison.OrdinalIgnoreCase)
            || hotel.Positioning.Contains(keyword, StringComparison.OrdinalIgnoreCase);
    }

    private void ResetFilters()
    {
        SearchText = "";
        SelectedCategory = "";
        SelectedGroup = "";
        SelectedCountry = "";
        SelectedEliteValue = "";
    }

    private static string GetCategoryClass(string category)
    {
        return category switch
        {
            "泳池飯店" => "pool",
            "溫泉飯店" => "onsen",
            _ => "mixed"
        };
    }

